#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

if ! command -v pi >/dev/null 2>&1; then
  echo "ERROR: pi is not on PATH. Run mise install first." >&2
  exit 1
fi

pi install npm:@howaboua/pi-codex-conversion@2.2.1
pi install npm:pi-web-access
pi install npm:pi-mcp-adapter
pi install npm:pi-subagents
pi install npm:pi-intercom
pi install npm:pi-prompt-template-model
pi install npm:pi-btw
pi install npm:pi-goal-x

# Keep the native single-port Tau fork pinned to the same release declared in
# pi-agent/settings.json. This ensures a fresh machine clones the Git package
# and installs its runtime dependencies during bootstrap.
pi install git:github.com/LumenYoung/tau@v1.2.0-native.0

visual_explainer_dir="${REPO_ROOT}/skills/vendor/visual-explainer"
if [[ -f "${visual_explainer_dir}/package.json" ]]; then
  # Install from the local submodule, not git/npm, so Pi deduplicates the package skill
  # with the skills/global/visual-explainer symlink by canonical SKILL.md path.
  pi install "${visual_explainer_dir}"
else
  echo "WARN: visual-explainer submodule is missing; run 'git submodule update --init --recursive'." >&2
fi

pi update --extensions
pi list
