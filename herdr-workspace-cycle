#!/usr/bin/env python3
"""Focus the next/previous Herdr workspace.

Used by Herdr custom keybindings to provide aliases in addition to Herdr's
single built-in next_workspace/previous_workspace bindings.
"""

import json
import subprocess
import sys


def main() -> int:
    direction = sys.argv[1] if len(sys.argv) > 1 else "next"
    if direction not in {"next", "previous"}:
        print("usage: herdr-workspace-cycle [next|previous]", file=sys.stderr)
        return 2

    raw = subprocess.check_output(["herdr", "workspace", "list"], text=True)
    workspaces = json.loads(raw)["result"]["workspaces"]
    if not workspaces:
        return 0

    focused_index = next(
        (index for index, workspace in enumerate(workspaces) if workspace.get("focused")),
        0,
    )
    step = 1 if direction == "next" else -1
    target = workspaces[(focused_index + step) % len(workspaces)]["workspace_id"]

    subprocess.run(["herdr", "workspace", "focus", target], check=True)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
