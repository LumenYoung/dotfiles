{
  "defaultProvider": "lumeny-openai",
  "defaultModel": "gpt-5.6-sol",
  "defaultThinkingLevel": "high",
  "transport": "sse",
  "compaction": {
    "enabled": true,
    "reserveTokens": 38400,
    "keepRecentTokens": 20000
  },
  "npmCommand": [
    "mise",
    "exec",
    "--",
    "npm"
  ],
  "packages": [
    "npm:@howaboua/pi-codex-conversion",
    "npm:pi-web-access",
    "npm:pi-mcp-adapter",
    "npm:pi-subagents",
    "npm:pi-intercom",
    "npm:pi-prompt-template-model",
    "npm:pi-btw",
    "npm:pi-goal-x",
    "../../dotfiles/skills/vendor/visual-explainer",
    "npm:pi-vim"
  ],
  "piVim": {
    "clipboardMirror": "never"
  },
  "lastChangelogVersion": "0.80.3",
  "theme": "dark"
}
