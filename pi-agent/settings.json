{
  "defaultProvider": "lumeny-openai",
  "defaultModel": "gpt-5.6-sol",
  "defaultThinkingLevel": "high",
  "transport": "sse",
  "compaction": {
    "enabled": true,
    "reserveTokens": 38400,
    "keepRecentTokens": 20000
  },
  "npmCommand": [
    "mise",
    "exec",
    "--",
    "npm"
  ],
  "packages": [
    {
      "source": "npm:@howaboua/pi-codex-conversion@2.2.1",
      "extensions": []
    },
    "./packages/openai-remote-compaction",
    "npm:pi-web-access",
    "npm:pi-mcp-adapter",
    "npm:pi-subagents",
    "npm:pi-intercom",
    "npm:pi-prompt-template-model",
    "npm:pi-btw",
    "npm:pi-goal-x",
    "git:github.com/LumenYoung/tau@v1.1.0-native.0",
    "../../dotfiles/skills/vendor/visual-explainer",
    "npm:pi-vim"
  ],
  "piVim": {
    "clipboardMirror": "never"
  },
  "lastChangelogVersion": "0.80.6",
  "theme": "dark"
}
